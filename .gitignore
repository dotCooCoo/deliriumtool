# ── Dotfiles: deny by default, allow-list only what should ship ───────
# Catches .env*, .dev.vars, .wrangler/, .vscode/, .idea/, .DS_Store,
# .claude/, and any other dotfile we don't explicitly intend to publish.
.*

# Dotfiles that DO belong in the repo
!.gitignore
!.gitattributes
!.editorconfig
!.nvmrc
!.github/
!.prettierrc.json
!.prettierignore

# ── Reference literature ──────────────────────────────────────────────
# The article PDFs are copyrighted full text — they are NEVER committed.
# The citation index is fine to publish.
references/*.pdf
!references/INDEX.md
# Verbatim journal abstracts reproduced for local reading — copyright, not published.
references/monitoring-burden-abstracts.md

# ── Build output & dependencies ───────────────────────────────────────
node_modules/
dist/
.wrangler/

# ── Test output ───────────────────────────────────────────────────────
test-results/
playwright-report/
blob-report/
coverage/
# Visual-regression baselines are platform-specific — generated on demand, not committed.
*-snapshots/

# ── Local clinical / patient data must never be committed ─────────────
# Anything a contributor saves, exports, or uses as a fixture locally.
*.phi
patient-*.json
assessment-*.json
/scratch/

# ── Credential & key material (belt-and-braces over the .* rule) ──────
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
secrets.json
credentials.json
id_rsa*
id_ed25519*

# ── OS / editor junk ──────────────────────────────────────────────────
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── Stray scratch images at the repo root ─────────────────────────────
# Screenshots and working images belong in /scratch/ (ignored) — this stops
# an accidental root-level capture from ever being committed. Real assets
# live under src/img/, never the root.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# nested reference archives (copyright — never commit)
references/**/*.pdf
references/peds/
# local working drafts (source documents for the printable templates)
references/template_output/
