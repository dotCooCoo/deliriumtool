# Security headers for the static site, applied by Cloudflare Workers (Static Assets).
# CSP is strict: 'self' only, no inline script or style, no external origins.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self'; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Content-hashed bundles — safe to cache forever; the filename changes on any edit.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons and the social card.
/img/*
  Cache-Control: public, max-age=604800

# The entry document must always revalidate so new hashed asset names are picked up.
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache
